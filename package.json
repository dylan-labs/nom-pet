{
  "name": "nom",
  "version": "0.0.24",
  "description": "A desktop pet that eats your AI tokens.",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit",
    "start": "electron-vite preview",
    "pack": "electron-vite build && electron-builder",
    "pack:mac": "electron-vite build && electron-builder --mac",
    "pack:win": "electron-vite build && electron-builder --win",
    "journal:test": "esbuild scripts/test-journal.mts --bundle --platform=node --format=esm --target=node20 --outfile=scripts/test-journal.bundle.mjs --packages=external && node scripts/test-journal.bundle.mjs --force",
    "tick:test": "esbuild scripts/test-tick.mts --bundle --platform=node --format=esm --target=node20 --outfile=scripts/test-tick.bundle.mjs --packages=external && node scripts/test-tick.bundle.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chokidar": "^4.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.8"
  }
}
